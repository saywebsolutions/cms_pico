<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if meta.title %}{{ meta.title }} | {% endif %}{{ site_title }}</title>
    {% if meta.description %}
    <meta name="description" content="{{ meta.description|striptags }}">
    {% endif %}
    {% if meta.robots %}
    <meta name="robots" content="{{ meta.robots|e('html_attr') }}">
    {% endif %}
    <link rel="stylesheet" href="{{ theme_url }}/style.css">
</head>
<body>
    <header>
        <h1><a href="{{ base_url }}">{{ site_title }}</a></h1>
        {% include "partials/nav.twig" %}
    </header>

    <main>
        {% if meta.title %}
        <h1>{{ meta.title }}</h1>
        {% endif %}

        {{ content|raw }}

        {% if config.comments_url %}
        <section id="comments">
            <h2>Comments</h2>
            <div id="remark42"></div>
            <script nonce="{{ config.csp_nonce }}">
                var remark_config = {
                    host: '{{ config.comments_url }}',
                    site_id: '{{ config.nextcloud_site }}',
                    url: window.location.origin + window.location.pathname,
                    theme: 'light',
                    locale: 'sv-SE'
                };
            </script>
            <script defer nonce="{{ config.csp_nonce }}" src="{{ config.comments_url }}/web/embed.js"></script>
        </section>
        {% endif %}
    </main>

    <footer>
    </footer>
</body>
</html>
