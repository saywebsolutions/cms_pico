{
  "name": "nextcloud/cms_pico",
  "description": "Create websites using Pico CMS for Nextcloud",
  "type": "project",
  "license": "AGPL-3.0-or-later",
  "authors": [
    {
      "name": "Maxence Lange",
      "email": "maxence@artificial-owl.com"
    },
    {
      "name": "Daniel Rudolf",
      "email": "picocms.org@daniel-rudolf.de"
    }
  ],
  "autoload": {
    "psr-4": {
      "OCA\\CMSPico\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\CMSPico\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2.0",
    "ext-json": "*",
    "erusev/parsedown": "^1.7.4",
    "erusev/parsedown-extra": "^0.8.1",
    "twig/twig": "^3.8",
    "xemlock/htmlpurifier-html5": "^0.1.11",
    "symfony/yaml": "^6.4|^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10|^11",
    "phrozenbyte/phpunit-throwable-asserts": "^1.1",
    "phrozenbyte/phpunit-array-asserts": "^v1.1"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
